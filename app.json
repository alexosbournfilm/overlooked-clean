{
  "expo": {
    "name": "Overlooked",
    "slug": "overlooked",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./app/assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "overlooked",
    "splash": {
      "image": "./app/assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.overlooked.app",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "overlooked"
            ]
          }
        ],
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library for profile uploads."
      },
      "associatedDomains": [
        "applinks:overlooked.cloud",
        "applinks:www.overlooked.cloud"
      ]
    },
    "android": {
      "package": "com.overlooked.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./app/assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "category": [
            "DEFAULT",
            "BROWSABLE"
          ],
          "data": [
            {
              "scheme": "overlooked",
              "host": "callback"
            },
            {
              "scheme": "overlooked",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "overlooked.cloud",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.overlooked.cloud",
              "pathPrefix": "/"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./public/ol-favicon-999.png",
      "display": "browser",
      "themeColor": "#0D0D0D",
      "backgroundColor": "#0D0D0D"
    },
    "extra": {
      "supabaseRedirectUrl": "overlooked://callback",
      "eas": {
        "projectId": "d572b8e6-d8d0-451e-bd76-df662912df85"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-iap",
      [
        "expo-notifications",
        {
          "color": "#F8A998",
          "defaultChannel": "default"
        }
      ]
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}